<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Bienvenido</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 flex items-center justify-center min-h-screen p-4">
    <div class="bg-white p-8 rounded-lg shadow-lg w-full max-w-2xl">
        <h1 class="text-3xl font-bold text-center text-gray-800 mb-6">Panel de Control</h1>

        {{#username}}
        <p class="text-xl text-center text-gray-700 mb-8">¡Bienvenido, <span class="font-semibold text-blue-600">{{username}}</span>!</p>
        {{/username}}
        {{^username}}
        <p class="text-xl text-center text-gray-700 mb-8">¡Bienvenido!</p>
        {{/username}}

        <!-- Sección Docentes -->
        <div class="bg-orange-50 border border-orange-200 p-6 rounded-lg shadow-sm mb-6">
            <h2 class="text-2xl font-bold text-orange-700 mb-3">Gestionar Docentes</h2>
            <p class="text-gray-600 mb-4">Consultá el listado o registrá un nuevo docente.</p>
            <div class="flex gap-3">
                <a href="/teacher"
                   class="inline-block bg-orange-600 text-white py-2 px-4 rounded-md hover:bg-orange-700 transition duration-300 text-sm">
                    Ver Listado
                </a>
                <a href="/teacher/new"
                   class="inline-block bg-white text-orange-600 border border-orange-600 py-2 px-4 rounded-md hover:bg-orange-50 transition duration-300 text-sm">
                    + Nuevo Docente
                </a>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
            <div class="bg-blue-50 border border-blue-200 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-2xl font-bold text-blue-700 mb-3">Tu Perfil</h2>
                <p class="text-gray-600 mb-4">Gestiona la información de tu cuenta.</p>
                <a href="/profile" class="inline-block bg-blue-600 text-white py-2 px-4 rounded-md hover:bg-blue-700 transition duration-300">Ver Perfil</a>
            </div>
            <div class="bg-green-50 border border-green-200 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-2xl font-bold text-green-700 mb-3">Configuraciones</h2>
                <p class="text-gray-600 mb-4">Ajusta las preferencias de tu aplicación.</p>
                <a href="/settings" class="inline-block bg-green-600 text-white py-2 px-4 rounded-md hover:bg-green-700 transition duration-300">Configuración</a>
            </div>
        </div>

        <div class="text-center mt-6">
            <a href="/logout" class="inline-block bg-red-600 text-white py-2 px-6 rounded-md hover:bg-red-700 transition duration-300 text-lg">Cerrar Sesión</a>
        </div>
    </div>
</body>
</html>